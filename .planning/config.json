{
  "mode": "interactive",
  "model_profile": "quality",
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "_auto_chain_active": true
  },
  "parallelization": {
    "enabled": true
  },
  "git": {
    "branching_strategy": "phase",
    "branch_templates": {
      "phase": "gsd/m{milestone}-p{phase}",
      "milestone": "gsd/milestone-{milestone}"
    }
  },
  "granularity": "standard",
  "gates": {
    "enabled": true,
    "lint": {
      "enabled": true,
      "command": "",
      "auto_detect": true
    },
    "architecture": {
      "enabled": true,
      "config_path": ".architecture.json"
    },
    "structural": {
      "enabled": true
    },
    "timeout_seconds": 10,
    "on_timeout": "warn"
  }
}