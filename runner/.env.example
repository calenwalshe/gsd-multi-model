# Claude Agent SDK
ANTHROPIC_API_KEY=sk-ant-xxx

# Runner configuration
MAX_TURNS=75
MAX_BUDGET_USD=5
COMPACTION_THRESHOLD=2
PROJECT_DIR=/path/to/your/gsd/project

# Telegram (home projects)
GSD_TELEGRAM_BOT_TOKEN=
GSD_TELEGRAM_CHAT_ID=

# Google Chat (work projects) — pick one notifier; Telegram takes priority if both set
GSD_GCHAT_SPACE_ID=spaces/AAAAxxxxxx
# GSD_GCHAT_AUTH_TOKEN=...  (TBD — bearer token, service account, or ADC)

# Shared gate/heartbeat timing
GATE_TIMEOUT_MS=14400000
HEARTBEAT_INTERVAL_MS=1800000
GCHAT_POLL_INTERVAL_MS=30000

# --- Codex Execution Routing ---
# Enable/disable multi-model routing (Codex for parallelizable tasks, Claude for sequential)
# Default: true (enabled when Codex CLI is installed and CODEX_ENABLED != 'false')
# Set to 'false' to force Claude-only execution even when Codex is installed.
CODEX_ENABLED=true

# Timeout in seconds for each Codex worktree task
# Default: 300 (5 minutes). Corresponds to codex.timeout_seconds in .planning/config.json.
# Override with this env var to skip editing config.json.
CODEX_TIMEOUT_SECONDS=300
